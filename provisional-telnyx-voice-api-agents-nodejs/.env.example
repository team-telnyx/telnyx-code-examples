# Telnyx API credentials
TELNYX_API_KEY=KEY_your_telnyx_api_key_here
TELNYX_PUBLIC_KEY=your_telnyx_webhook_public_key_here

# Reusable base Telnyx AI Assistant used for live calls
BASE_ASSISTANT_ID=assistant-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Local server
PORT=5000

# Optional outbound test call
TELNYX_CONNECTION_ID=your_call_control_connection_id
TELNYX_FROM_NUMBER=+15551111111
TEST_TO_NUMBER=+15552222222
