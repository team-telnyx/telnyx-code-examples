# Existing AI chatbot's OpenAI-compatible endpoint.
# Clawdbot/Nyx gateway example: http://localhost:18789 with model "openclaw".
CHATBOT_BASE_URL=http://localhost:18789
CHATBOT_TOKEN=your_gateway_auth_token
CHATBOT_MODEL=openclaw

# LLM response tuning
MAX_TOKENS=150
REQUEST_TIMEOUT=20

# Public HTTPS URL of THIS app (your ngrok URL). Leave blank to auto-detect.
TELNYX_PUBLIC_BASE_URL=https://your-tunnel.ngrok.app

# Voice / transcription
WELCOME_GREETING=Hi! This is Nyx. Ask me anything and I'll do my best to help.
VOICE=Telnyx.Natural.abbie
LANGUAGE=en
TRANSCRIPTION_PROVIDER=deepgram

# Server
HOST=0.0.0.0
PORT=8000
