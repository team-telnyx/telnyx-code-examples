# Telnyx API credentials — get yours at https://portal.telnyx.com

# Telnyx API v2 key — https://portal.telnyx.com/app/api-keys
TELNYX_API_KEY=your_telnyx_api_key_here

# Telnyx public key for webhook signature verification —
# https://portal.telnyx.com/app/account/public-key
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here

# Telnyx phone number in E.164 format used as the SMS sender
TELNYX_PHONE_NUMBER=+15551234567

# Port the Express server listens on
PORT=3000
