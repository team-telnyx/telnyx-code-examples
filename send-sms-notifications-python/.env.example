# Telnyx API credentials — get yours at https://portal.telnyx.com

TELNYX_API_KEY=your_telnyx_api_key_here
# Required to verify inbound webhook signatures (Portal > Account > Keys & Credentials > Public Key)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
TELNYX_PHONE_NUMBER=+15551234567
WEBHOOK_URL=https://your-domain.com/api/webhooks/sms
FLASK_ENV=development
FLASK_DEBUG=false
